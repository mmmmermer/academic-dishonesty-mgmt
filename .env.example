# ============================================================
# 校园学术失信人员管理系统 — 环境变量配置示例
# ============================================================
# 复制本文件为 .env 或在系统环境中设置以下变量。
# !! 切勿将含有真实密码的 .env 提交到版本库 !!

# ---------- 数据库连接 ----------
# 不设置时默认使用 SQLite（项目根目录 database.db），适合本地开发。
# 生产环境建议使用 MySQL 或 PostgreSQL。

# MySQL 示例（需 pip install pymysql）：
# DATABASE_URL=mysql+pymysql://用户名:密码@主机:3306/库名?charset=utf8mb4

# PostgreSQL 示例（需 pip install psycopg2-binary）：
# DATABASE_URL=postgresql+psycopg2://用户名:密码@主机:5432/库名

# ---------- SQLite 回退模式（本地开发用） ----------
# 系统默认要求 PostgreSQL。本地开发若无 PostgreSQL，
# 需显式设置此变量为 1 才能使用 SQLite：
# ALLOW_SQLITE_FALLBACK=1

# ---------- 多实例部署（可选） ----------
# 设为 1 启用多实例检查；多实例下必须使用 MySQL 或 PostgreSQL，禁止 SQLite。
# MULTI_INSTANCE=0
